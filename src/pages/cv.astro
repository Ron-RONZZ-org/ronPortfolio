---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';
import cvMeta from '../content/cv/meta.json';

const allEntries = await getCollection('cv');

// Merge with meta.json (shared fields + translated titles)
const enriched = allEntries.map(entry => {
  const m = cvMeta[entry.data.id];
  if (!m) return entry;
  const t = m.translations?.[entry.data.language] ?? {};
  return {
    ...entry,
    data: {
      id: entry.data.id,
      language: entry.data.language,
      category: m.category,
      start: m.start,
      end: m.end,
      icon: m.icon ?? '',
      logo: m.logo,
      sortOrder: m.sortOrder ?? 0,
      title: t.title ?? entry.data.id,
    },
  };
});

// Group by language
const grouped: Record<string, typeof enriched> = {};
for (const entry of enriched) {
  const lang = entry.data.language;
  if (!grouped[lang]) grouped[lang] = [];
  grouped[lang].push(entry);
}

// Sort each group: newest first, then sortOrder
for (const lang of Object.keys(grouped)) {
  grouped[lang].sort((a, b) => {
    const endA = a.data.end ?? 9999;
    const endB = b.data.end ?? 9999;
    if (endB !== endA) return endB - endA;
    const startA = a.data.start;
    const startB = b.data.start;
    if (startB !== startA) return startB - startA;
    return (a.data.sortOrder ?? 0) - (b.data.sortOrder ?? 0);
  });
}

// Pre-render all entries so we can use Content in the template
const langs = ['en', 'fr', 'zh', 'eo'] as const;

type RenderedEntry = {
  entry: typeof enriched[number];
  Content: any;
};
const rendered: RenderedEntry[] = [];
for (const lang of langs) {
  for (const entry of grouped[lang] ?? []) {
    const { Content } = await entry.render();
    rendered.push({ entry, Content });
  }
}
---

<Base titleKey="page_title_cv" title="CV & Timeline - Ron's Portfolio">
  <header>
    <h1 data-i18n="my_journey">My Journey</h1>
    <p class="bio" data-i18n="journey_bio">
      A timeline of my education, work experience, achievements, and personal milestones.
    </p>
  </header>

  <div class="filter-buttons">
    <button class="filter-btn education active" data-filter="education" data-i18n="filter_education">Education</button>
    <button class="filter-btn work active" data-filter="work" data-i18n="filter_work">Work</button>
    <button class="filter-btn achievement active" data-filter="achievement" data-i18n="filter_achievement">Achievements</button>
    <button class="filter-btn personal active" data-filter="personal" data-i18n="filter_personal">Personal</button>
    <button class="filter-btn select-all" data-filter="select-all" data-i18n="filter_select_all">Select All</button>
    <button class="filter-btn deselect-all" data-filter="deselect-all" data-i18n="filter_deselect_all">Deselect All</button>
  </div>

  <main class="timeline" id="timeline">
    {
      rendered.map(({ entry, Content }) => {
        const icon = entry.data.icon ?? '';
        const period = entry.data.end
          ? `${entry.data.start} – ${entry.data.end}`
          : `${entry.data.start} – Present`;

        return (
          <div
            class={`milestone ${entry.data.category}`}
            data-category={entry.data.category}
            data-lang-content={entry.data.language}
          >
            <div class="milestone-marker"></div>
            <div class="milestone-content">
              <div class="milestone-time">{period}</div>
              <h3 class="milestone-title">
                {icon ? `${icon} ` : ''}{entry.data.title}
              </h3>
              {entry.body && Content && (
                <div class="milestone-details">
                  <Content />
                </div>
              )}
              {entry.data.logo && (
                <img
                  class="milestone-logo"
                  src={entry.data.logo}
                  alt="Logo"
                  onerror="this.style.display='none'"
                />
              )}
            </div>
          </div>
        );
      })
    }
  </main>

  <nav>
    <a href="/" class="back-link" data-i18n="back_to_home">← Back to Home</a>
  </nav>
</Base>

<script is:inline>
  // Multi-select category filter — works on visible (non-hidden-by-lang) milestones
  document.addEventListener('DOMContentLoaded', () => {
    const timeline = document.getElementById('timeline');
    const categoryButtons = document.querySelectorAll('.filter-btn.education, .filter-btn.work, .filter-btn.achievement, .filter-btn.personal');
    const selectAllBtn = document.querySelector('.filter-btn.select-all');
    const deselectAllBtn = document.querySelector('.filter-btn.deselect-all');
    let selectedCategories = new Set();

    function applyFilter() {
      const milestones = timeline?.querySelectorAll('.milestone') ?? [];
      const noSelection = selectedCategories.size === 0;
      milestones.forEach(m => {
        const hiddenByLang = m.classList.contains('hidden-by-lang');
        if (noSelection) {
          m.classList.toggle('hidden', true);
        } else {
          const cat = m.getAttribute('data-category');
          m.classList.toggle('hidden', !selectedCategories.has(cat) || hiddenByLang);
        }
      });
    }

    // Individual category toggle
    categoryButtons.forEach(btn => {
      btn.addEventListener('click', () => {
        const filter = btn.getAttribute('data-filter');
        if (selectedCategories.has(filter)) {
          selectedCategories.delete(filter);
          btn.classList.remove('active');
        } else {
          selectedCategories.add(filter);
          btn.classList.add('active');
        }
        applyFilter();
      });
    });

    // Select All
    selectAllBtn?.addEventListener('click', () => {
      categoryButtons.forEach(b => {
        selectedCategories.add(b.getAttribute('data-filter'));
        b.classList.add('active');
      });
      applyFilter();
    });

    // Deselect All
    deselectAllBtn?.addEventListener('click', () => {
      selectedCategories.clear();
      categoryButtons.forEach(b => b.classList.remove('active'));
      applyFilter();
    });

    // Start with all categories selected
    categoryButtons.forEach(b => {
      selectedCategories.add(b.getAttribute('data-filter'));
    });
    applyFilter();

    // Re-apply filter when language changes
    if (timeline) {
      const observer = new MutationObserver(() => applyFilter());
      observer.observe(timeline, {
        attributes: false,
        childList: false,
        subtree: true,
        attributeFilter: ['class'],
      });
    }
  });
</script>

<style is:global>
  .hidden-by-lang { display: none; }
</style>
