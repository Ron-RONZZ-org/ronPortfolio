---
import Base from '../layouts/Base.astro';
---

<Base titleKey="page_title_contact" title="Contact - Ron's Portfolio">
  <header>
    <h1 data-i18n="get_in_touch">Get In Touch</h1>
    <p class="bio" data-i18n="contact_bio">
      Feel free to email me. I'm always happy to connect!
    </p>
  </header>

  <main>
    <div class="contact-card">
      <h2 data-i18n="contact_information">Contact Information</h2>

      <div class="contact-item">
        <span class="contact-icon">📧</span>
        <div class="contact-info">
          <div class="contact-label" data-i18n="email_me">Email me</div>
          <div class="contact-value"><a href="mailto:hi@rongzhou.me">hi@rongzhou.me</a></div>
        </div>
      </div>

      <div class="contact-item">
        <span class="contact-icon">📍</span>
        <div class="contact-info">
          <div class="contact-label" data-i18n="write_to_me">Write to me</div>
          <div class="contact-value">
            UFR Mathématiques, Informatique,<br />
            Mécanique et Automatique (MIM)<br />
            3 Rue Augustin Fresnel<br />
            FR-57070 METZ, FRANCE<br />
            UNION EUROPÉENNE — EUROPEAN UNION
          </div>
        </div>
      </div>
    </div>
  </main>

  <nav>
    <a href="/" class="back-link" data-i18n="back_to_home">← Back to Home</a>
  </nav>
</Base>
