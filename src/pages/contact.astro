---
import Base from '../layouts/Base.astro';
---

<Base titleKey="page_title_contact" title="Contact - Ron's Portfolio">
  <header>
    <h1 data-i18n="get_in_touch">Get In Touch</h1>
    <p class="bio" data-i18n="contact_bio">
      Feel free to email me. I'm always happy to connect!
    </p>
  </header>

  <main>
    <div class="contact-card">
      <h2 data-i18n="contact_information">Contact Information</h2>

      <div class="contact-item">
        <span class="contact-icon">📧</span>
        <div class="contact-info">
          <div class="contact-label" data-i18n="email">Email</div>
          <div class="contact-value"><a href="mailto:hi@rongzhou.me">hi@rongzhou.me</a></div>
        </div>
      </div>

      <div class="contact-item">
        <span class="contact-icon">📍</span>
        <div class="contact-info">
          <div class="contact-label" data-i18n="location">Location</div>
          <div class="contact-value" data-i18n="location_value">🇫🇷France, 🇪🇺The European Union</div>
        </div>
      </div>

      <div class="contact-item">
        <span class="contact-icon">🎓</span>
        <div class="contact-info">
          <div class="contact-label" data-i18n="organization">Organization</div>
          <div class="contact-value">Université de Lorraine</div>
        </div>
      </div>

      <div class="contact-item">
        <span class="contact-icon">💻</span>
        <div class="contact-info">
          <div class="contact-label" data-i18n="address">Address</div>
          <div class="contact-value">
            Université de Lorraine – IUT Épinal Hubert Curien<br />
            7 rue des Fusillés de la Résistance<br />
            88000 ÉPINAL France
          </div>
        </div>
      </div>
    </div>
  </main>

  <nav>
    <a href="/" class="back-link" data-i18n="back_to_home">← Back to Home</a>
  </nav>
</Base>
